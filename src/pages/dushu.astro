---
import "../styles/global.css";
import { frontmatter as project } from "../content/projects/dushu.md";

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content={project.description}
    />
    <title>{project.title} | Joshua Lykes</title>
  </head>
  <body>
    <div class="page detail-page">
      <header class="topbar">
        <a class="home-link" href="/" aria-label="Home">
          <svg aria-hidden="true" viewBox="0 0 24 24">
            <path d="M3 10.5 12 3l9 7.5" />
            <path d="M5.5 9.5V21h13V9.5" />
            <path d="M9.5 21v-7h5v7" />
          </svg>
        </a>
        <nav class="nav" aria-label="Project navigation">
          <a href={project.videoOverviewUrl}>Video overview</a>
        </nav>
      </header>

      <main>
        <section class="detail-hero" aria-labelledby="page-title">
          <div class="detail-hero-copy">
            <p class="detail-kicker">{project.kicker}</p>
            <h1 id="page-title">{project.title}</h1>
            <p class="detail-subtitle">{project.subtitle}</p>
            <p class="detail-lede">{project.description}</p>
            <div class="detail-meta" aria-label="Project metadata">
              {project.meta.map((item) => <span>{item}</span>)}
            </div>
          </div>

          <div class="detail-hero-media">
            <img
              src={project.heroImage}
              alt={project.heroImageAlt}
            />
          </div>
        </section>

        <section class="detail-section text-section" aria-labelledby="problem-title">
          <h2 id="problem-title">The Problem</h2>
          <div class="detail-prose">
            {project.problem.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </section>

        <section class="detail-section" aria-labelledby="does-title">
          <div class="section-header section-header-simple">
            <h2 id="does-title">Functionality</h2>
          </div>
          <p class="section-note">
            You can see a video describing the app and its functionality here:
            <a href={project.videoOverviewUrl}>{project.videoOverviewLabel}</a>.
          </p>

          <div class="feature-stack">
            {project.functionality.map((feature) => (
              <article class="feature-block">
                {feature.image ? (
                  <button
                    class="feature-image-button"
                    type="button"
                    data-modal-image={feature.image}
                    data-modal-alt={feature.imageAlt ?? feature.title}
                    aria-label={`Open larger image for ${feature.title}`}
                  >
                    <img class="feature-image" src={feature.image} alt={feature.imageAlt ?? ""} />
                  </button>
                ) : (
                  <div class="placeholder-image">
                    <span>{feature.placeholder}</span>
                  </div>
                )}
                <div class="feature-copy">
                  <h3>{feature.title}</h3>
                  <p>{feature.body}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="detail-section built-section" aria-labelledby="built-title">
          <div class="section-media-column">
            <h2 id="built-title">How I Built It</h2>
          </div>
          <div class="detail-prose">
            {project.howBuilt.map((paragraph) => <p>{paragraph}</p>)}
            <div class="placeholder-image wide-placeholder">
              <span>{project.technicalDiagramPlaceholder}</span>
            </div>
          </div>
        </section>

        <section class="detail-section text-section" aria-labelledby="state-title">
          <h2 id="state-title">Current State And Next Steps</h2>
          <div class="detail-prose">
            {project.currentState.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </section>
      </main>
    </div>
    <div class="image-modal" data-image-modal hidden>
      <button class="image-modal-close" type="button" data-modal-close aria-label="Close image">
        <span aria-hidden="true">&times;</span>
      </button>
      <div class="image-modal-frame">
        <img data-modal-img src="" alt="" />
      </div>
    </div>
    <script>
      const modal = document.querySelector("[data-image-modal]");
      const modalImage = document.querySelector("[data-modal-img]");
      const closeButton = document.querySelector("[data-modal-close]");
      const imageButtons = document.querySelectorAll("[data-modal-image]");

      const closeModal = () => {
        if (!(modal instanceof HTMLElement) || !(modalImage instanceof HTMLImageElement)) {
          return;
        }

        modal.hidden = true;
        modalImage.src = "";
        modalImage.alt = "";
        document.body.classList.remove("modal-open");
      };

      imageButtons.forEach((button) => {
        button.addEventListener("click", () => {
          if (!(modal instanceof HTMLElement) || !(modalImage instanceof HTMLImageElement)) {
            return;
          }

          const imageSrc = button.getAttribute("data-modal-image");
          if (!imageSrc) {
            return;
          }

          modalImage.src = imageSrc;
          modalImage.alt = button.getAttribute("data-modal-alt") ?? "";
          modal.hidden = false;
          document.body.classList.add("modal-open");
          if (closeButton instanceof HTMLButtonElement) {
            closeButton.focus();
          }
        });
      });

      closeButton?.addEventListener("click", closeModal);

      modal?.addEventListener("click", (event) => {
        if (event.target === modal) {
          closeModal();
        }
      });

      modalImage?.addEventListener("click", closeModal);

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeModal();
        }
      });
    </script>
  </body>
</html>
